# Database
DATABASE_URL="postgresql://username:password@localhost:5432/stylematch"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-here"

# OAuth Providers
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
LINE_CLIENT_ID="your-line-client-id"
LINE_CLIENT_SECRET="your-line-client-secret"

# Email (SendGrid)
SENDGRID_API_KEY="your-sendgrid-api-key"
EMAIL_FROM="noreply@stylematch.jp"

# AI Service (Hair Style Recommendation)
AI_SERVICE_URL="http://localhost:8000"
AI_SERVICE_API_KEY="development-key"

# AWS S3 (Image Upload)
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="ap-northeast-1"
AWS_S3_BUCKET="stylematch-images"
CDN_URL="https://cdn.stylematch.jp"

# Payment (Stripe)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Video Service (Twilio/Agora/Daily.co)
VIDEO_SERVICE_API_KEY="your-video-service-key"
VIDEO_SERVICE_SECRET="your-video-service-secret"

# Environment
NODE_ENV="development"